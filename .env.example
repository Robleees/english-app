# ──────────────────────────────────────────────────────────────────────────────
# EnglishApp — Variables de entorno
# Copia este archivo como backend/.env y rellena los valores reales.
# NUNCA subas .env al repositorio.
# ──────────────────────────────────────────────────────────────────────────────

# ── Backend (backend/.env) ────────────────────────────────────────────────────

# Clave de la Anthropic API (claude-sonnet-4-20250514)
# Obtener en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Clave de NewsAPI (plan gratuito = 100 req/día)
# Obtener en: https://newsapi.org/register
NEWS_API_KEY=...

# Clave secreta de Flask para sesiones y JWT
SECRET_KEY=cambia-esto-por-algo-random-en-produccion

# URL de base de datos — SQLite en dev, PostgreSQL en prod
DATABASE_URL=sqlite:///app.db
# DATABASE_URL=postgresql://user:password@host:5432/englishapp

# Orígenes permitidos para CORS (separados por coma si hay más de uno)
CORS_ORIGINS=http://localhost:5173

# ── Frontend (frontend/.env.local) ───────────────────────────────────────────

# URL base del backend Flask
VITE_API_BASE_URL=http://localhost:5000
